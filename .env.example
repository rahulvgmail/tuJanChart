# Flask
FLASK_APP=main:create_app
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# Database
DATABASE_URL=postgresql://stockpulse:stockpulse@localhost:5432/stockpulse

# Redis
REDIS_URL=redis://localhost:6379/0

# Data source adapter: yfinance | kite
DATA_ADAPTER=yfinance

# Gap threshold (%)
GAP_THRESHOLD=3.0

# Volume breakout periods
VOLUME_MAX_PERIOD=21
VOLUME_AVG_SHORT_PERIOD=140
VOLUME_AVG_LONG_PERIOD=280

# Result proximity windows (days)
RESULT_WINDOW_SHORT=7
RESULT_WINDOW_MEDIUM=10
RESULT_WINDOW_LONG=15
RESULT_DECLARED_WINDOW=10

# Admin seed
ADMIN_EMAIL=admin@stockpulse.local
ADMIN_PASSWORD=changeme
